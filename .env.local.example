# ============================================================
# Beauty.dev — local-dev .env
# Скопируй в .env (в корне репо) и заполни TELEGRAM_BOT_TOKEN +
# KIE_API_KEY (или DEEPSEEK_API_KEY). Остальное оставь как есть.
# ============================================================

# ---------- Postgres / Redis (через docker compose up db redis) ----------
POSTGRES_USER=beauty
POSTGRES_PASSWORD=beauty
POSTGRES_DB=beautybot
DATABASE_URL=postgresql+asyncpg://beauty:beauty@127.0.0.1:5433/beautybot
REDIS_URL=redis://127.0.0.1:6380/0

# ---------- Telegram ----------
# Тот же токен, что и в проде. Полученный от @BotFather.
TELEGRAM_BOT_TOKEN=
TELEGRAM_BOT_USERNAME=beauty_dev_bot

# Пустой → бэкенд переходит в режим long-polling (нужно для локалки).
TELEGRAM_WEBHOOK_URL=
TELEGRAM_WEBHOOK_SECRET=
TELEGRAM_BOT_SECRET=

# ---------- LLM ----------
# Используй тот же провайдер, что и в проде.
LLM_PROVIDER=kie
KIE_API_KEY=
KIE_API_BASE=https://api.kie.ai
KIE_MODEL=gpt-5-2
KIE_REASONING_EFFORT=low

DEEPSEEK_API_KEY=
DEEPSEEK_API_BASE=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat

# ---------- Mini App / public URLs (локально не критично) ----------
MINI_APP_URL=http://localhost:5173
PUBLIC_API_URL=http://localhost:8001/api
PUBLIC_PORTFOLIO_URL=http://localhost:8001/portfolio
DOMAIN=localhost
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:8001

# ---------- Окружение ----------
SECRET_KEY=local-dev-not-for-production
ENVIRONMENT=development
LOG_LEVEL=INFO
DEFAULT_TIMEZONE=Europe/Moscow

# ---------- Портфолио (Windows-friendly путь) ----------
PORTFOLIO_STORAGE_PATH=./portfolio_local
PORTFOLIO_MAX_FILE_SIZE_MB=10

# ---------- Биллинг — дефолты, не трогай ----------
TRIAL_DAYS=14
PRO_PRICE_MONTHLY=900
PRO_PLUS_PRICE_MONTHLY=2400
ANNUAL_DISCOUNT_PERCENT=20

# ---------- Бот ----------
HUMAN_TAKEOVER_HOURS=24
SLOT_LOCK_MINUTES=5
MAX_SERVICES_PER_MASTER=20
LLM_HISTORY_MESSAGES=20

# ---------- Без прокси для локалки ----------
HTTP_PROXY_URL=
DEEPSEEK_PROXY_URL=

# ---------- YooKassa — пустые на локалке ----------
YOOKASSA_SHOP_ID=
YOOKASSA_SECRET_KEY=
YOOKASSA_RETURN_URL=
YOOKASSA_WEBHOOK_URL=
