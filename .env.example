# ============================================================
# Beauty.dev — .env.example
# Скопируй в .env и заполни значения. Реальный .env в git НЕ попадает.
# ============================================================

# ---------- Доступ к серверу (Timeweb Cloud) ----------
SERVER_HOST=
SERVER_SSH_USER=root
SERVER_SSH_PORT=22
SERVER_SSH_PASSWORD=

# ---------- GitHub ----------
GITHUB_REPO_URL=https://github.com/sotnev2024-code/beauty-bot.git
GITHUB_USERNAME=
GITHUB_PAT=
GIT_USER_NAME=
GIT_USER_EMAIL=

# ---------- База данных (PostgreSQL) ----------
POSTGRES_USER=beauty
POSTGRES_PASSWORD=CHANGE_ME
POSTGRES_DB=beautybot
DATABASE_URL=postgresql+asyncpg://beauty:CHANGE_ME@db:5432/beautybot

# ---------- Redis ----------
REDIS_URL=redis://redis:6379/0

# ---------- Telegram ----------
TELEGRAM_BOT_TOKEN=
TELEGRAM_BOT_USERNAME=beauty_dev_bot
TELEGRAM_WEBHOOK_URL=https://crm.plus-shop.ru/api/telegram/webhook
TELEGRAM_WEBHOOK_SECRET=
TELEGRAM_BOT_SECRET=

# ---------- Mini App / публичные URL ----------
MINI_APP_URL=https://crm.plus-shop.ru
PUBLIC_API_URL=https://crm.plus-shop.ru/api
PUBLIC_PORTFOLIO_URL=https://crm.plus-shop.ru/portfolio
DOMAIN=crm.plus-shop.ru

# ---------- DeepSeek LLM ----------
DEEPSEEK_API_KEY=
DEEPSEEK_API_BASE=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-v4-flash

# ---------- YooKassa ----------
YOOKASSA_SHOP_ID=
YOOKASSA_SECRET_KEY=
YOOKASSA_RETURN_URL=https://crm.plus-shop.ru/billing/return
YOOKASSA_WEBHOOK_URL=https://crm.plus-shop.ru/api/billing/yookassa-webhook

# ---------- Безопасность / окружение ----------
SECRET_KEY=
ENVIRONMENT=production
LOG_LEVEL=INFO
ALLOWED_ORIGINS=https://crm.plus-shop.ru
DEFAULT_TIMEZONE=Europe/Moscow

# ---------- Let's Encrypt ----------
LETSENCRYPT_EMAIL=

# ---------- Портфолио ----------
PORTFOLIO_STORAGE_PATH=/var/www/portfolio
PORTFOLIO_MAX_FILE_SIZE_MB=10

# ---------- Биллинг ----------
TRIAL_DAYS=14
PRO_PRICE_MONTHLY=900
PRO_PLUS_PRICE_MONTHLY=2400
ANNUAL_DISCOUNT_PERCENT=20

# ---------- Бизнес-логика бота ----------
HUMAN_TAKEOVER_HOURS=24
SLOT_LOCK_MINUTES=5
MAX_SERVICES_PER_MASTER=20
LLM_HISTORY_MESSAGES=20
